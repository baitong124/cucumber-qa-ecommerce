{
  "name": "cucumber-qa-ecommerce",
  "version": "1.0.0",
  "description": "Cucumber-JS + Playwright (TypeScript) BDD suite for the QA Practice auth_ecommerce flow (login → cart → shipping → confirmation).",
  "type": "commonjs",
  "scripts": {
    "test": "cucumber-js",
    "test:ui": "cucumber-js --tags \"not @api\"",
    "test:api": "cucumber-js --tags @api",
    "test:clean": "cucumber-js --tags \"not @known-issue\"",
    "test:known-issues": "cucumber-js --tags @known-issue",
    "test:ui:clean": "cucumber-js --tags \"not @api and not @known-issue\"",
    "test:api:clean": "cucumber-js --tags \"@api and not @known-issue\"",
    "test:ui:known": "cucumber-js --tags \"@known-issue and not @api\" --format \"html:reports/known-issues.html\"",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:positive": "cucumber-js --tags @positive",
    "test:negative": "cucumber-js --tags @negative",
    "test:headed": "HEADLESS=false cucumber-js --tags \"not @api\"",
    "typecheck": "tsc --noEmit",
    "dry": "cucumber-js --dry-run",
    "report": "echo \"HTML report written to reports/cucumber-report.html\""
  },
  "keywords": [
    "cucumber",
    "playwright",
    "bdd",
    "typescript",
    "qa"
  ],
  "author": "QA Engineering",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@playwright/test": "1.45",
    "@types/node": "^20.19.43",
    "ts-node": "^10.9.2",
    "typescript": "5.5"
  }
}
